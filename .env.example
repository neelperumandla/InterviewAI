# ── Required API keys ─────────────────────────────────────────────────────────
# Use one GEMINI_API_KEY for all agents, or set per-agent keys below.
GEMINI_API_KEY=
TAVILY_API_KEY=

# Optional per-agent Gemini keys (leave blank if using GEMINI_API_KEY)
GEMINI_API_KEY_ORCHESTRATOR=
GEMINI_API_KEY_RESEARCH=
GEMINI_API_KEY_INTERVIEW=
GEMINI_API_KEY_EVALUATION=
GEMINI_API_KEY_CRITIC=
GEMINI_API_KEY_MEMORY=

# ── Server (Railway sets PORT automatically) ────────────────────────────────
PORT=8000
API_HOST=0.0.0.0
# API_PORT is only used locally if PORT is unset
API_PORT=8001

# ── Production: SQLite on a Railway volume mount at /data ───────────────────
DATA_DIR=/data
# Or set explicit paths:
# DB_PATH=/data/interview_memory.db
# HISTORY_DB_PATH=/data/candidate_history.db

# ── CORS: comma-separated frontend origins (required for Vercel) ───────────
# Example: https://your-app.vercel.app,https://your-app-*.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Optional tuning ─────────────────────────────────────────────────────────
SKIP_CRITIQUE_LLM=true
PASS_SCORE_THRESHOLD=60
RESEARCH_CACHE_DAYS=30
CALIBRATION_QUESTION_COUNT=3
